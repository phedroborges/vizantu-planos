# URL publica do projeto. Usada para montar os links compartilhados.
# Na VPS, use o subdominio com https (ex.: https://planos.metricz.com.br).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Armazenamento ---
# "local" guarda tudo em disco (pasta definida em DATA_DIR). Use na VPS/EasyPanel.
# Se ficar vazio, o app tenta detectar Vercel/Netlify Blob pelos tokens abaixo.
STORAGE_DRIVER=local

# Pasta de dados quando STORAGE_DRIVER=local (planos, metadados e aprovacoes).
# Na VPS aponte para um volume persistente montado no container (ex.: /data).
DATA_DIR=/data

# --- Vercel Blob (so quando hospedado na Vercel; deixe vazio na VPS) ---
BLOB_READ_WRITE_TOKEN=
