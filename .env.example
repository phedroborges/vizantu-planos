# Unica variavel obrigatoria. Senha compartilhada para acessar o painel.
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Opcional. Quando vazio, o app deriva o segredo da senha administrativa.
SESSION_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Criada automaticamente ao conectar um Vercel Blob Store ao projeto.
BLOB_READ_WRITE_TOKEN=

# URL publica do projeto. Usada para montar os links compartilhados.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
